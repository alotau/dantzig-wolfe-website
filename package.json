    "pako": "^2.1.0",
    "rehype-katex": "^7.0.0",
    "remark-math": "^6.0.0",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
