---
import BaseLayout from '../components/layout/BaseLayout.astro'
import NavBar from '../components/layout/NavBar.astro'
import Footer from '../components/layout/Footer.astro'
import GlossaryPanel from '../components/layout/GlossaryPanel.svelte'
import { getCollection } from 'astro:content'

const glossaryEntries = await getCollection('glossary')
const glossaryData = glossaryEntries.map((e) => ({
  term: e.data.term,
  shortDef: e.data.shortDef,
  relatedTerms: e.data.relatedTerms,
  slug: e.slug,
}))

const sections = [
  {
    href: '/history',
    label: 'History',
    icon: '📜',
    teaser:
      'Discover the origins of Dantzig-Wolfe Decomposition, its relationship to the Simplex method, and its landmark industrial applications.',
  },
  {
    href: '/lesson',
    label: 'Lesson',
    icon: '📐',
    teaser:
      'Work through a structured technical lesson covering the master problem, sub-problems, column generation, and convergence — with full KaTeX notation.',
  },
  {
    href: '/examples',
    label: 'Examples',
    icon: '📊',
    teaser:
      'Explore three worked examples from the literature — cutting stock, multi-commodity flow, and crew scheduling — with explicit iteration traces.',
  },
  {
    href: '/solver',
    label: 'Solver',
    icon: '⚡',
    teaser:
      'Run Dantzig-Wolfe decomposition on your own problem directly in your browser. No server required — the solver runs via Pyodide (Python on WebAssembly).',
  },
]
---

<BaseLayout
  title="Dantzig-Wolfe Decomposition"
  description="An interactive educational resource for Dantzig-Wolfe Decomposition — history, lesson, worked examples, and an in-browser solver."
>
  <NavBar slot="nav" />

  <!-- Hero -->
  <section
    class="relative overflow-hidden text-[var(--color-text-inverse)] py-20 px-4"
    style="background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #0c4a6e 100%);"
  >
    <!-- Decorative block-angular matrix SVG (the structure DW decomposes) -->
    <div class="pointer-events-none absolute inset-y-0 right-0 w-1/2 flex items-center justify-end pr-6 opacity-10" aria-hidden="true">
      <svg viewBox="0 0 200 160" width="340" height="272" xmlns="http://www.w3.org/2000/svg" fill="none">
        <!-- Outer border -->
        <rect x="2" y="2" width="196" height="156" rx="2" stroke="white" stroke-width="1.5"/>
        <!-- Row separators -->
        <line x1="2" y1="42" x2="198" y2="42" stroke="white" stroke-width="1"/>
        <line x1="2" y1="82" x2="198" y2="82" stroke="white" stroke-width="1"/>
        <line x1="2" y1="122" x2="198" y2="122" stroke="white" stroke-width="1"/>
        <!-- Col separator (master | subproblems) -->
        <line x1="70" y1="2" x2="70" y2="158" stroke="white" stroke-width="1"/>
        <!-- Sub-problem vertical separators -->
        <line x1="120" y1="42" x2="120" y2="158" stroke="white" stroke-width="0.75" stroke-dasharray="3 2"/>
        <!-- Master problem block (top-left) - filled cells -->
        <rect x="8" y="8" width="24" height="8" rx="1" fill="white" opacity="0.9"/>
        <rect x="38" y="8" width="24" height="8" rx="1" fill="white" opacity="0.9"/>
        <rect x="8" y="22" width="24" height="8" rx="1" fill="white" opacity="0.6"/>
        <rect x="38" y="22" width="24" height="8" rx="1" fill="white" opacity="0.9"/>
        <rect x="8" y="36" width="24" height="4" rx="1" fill="white" opacity="0.9"/>
        <rect x="38" y="36" width="24" height="4" rx="1" fill="white" opacity="0.6"/>
        <!-- Sub-problem 1 (mid row, left block) -->
        <rect x="76" y="48" width="18" height="7" rx="1" fill="white" opacity="0.85"/>
        <rect x="100" y="48" width="14" height="7" rx="1" fill="white" opacity="0.6"/>
        <rect x="76" y="61" width="14" height="7" rx="1" fill="white" opacity="0.6"/>
        <rect x="100" y="61" width="18" height="7" rx="1" fill="white" opacity="0.85"/>
        <rect x="76" y="74" width="18" height="5" rx="1" fill="white" opacity="0.85"/>
        <!-- Sub-problem 2 (mid row, right block) -->
        <rect x="126" y="48" width="18" height="7" rx="1" fill="white" opacity="0.85"/>
        <rect x="150" y="48" width="14" height="7" rx="1" fill="white" opacity="0.5"/>
        <rect x="126" y="61" width="14" height="7" rx="1" fill="white" opacity="0.5"/>
        <rect x="150" y="61" width="18" height="7" rx="1" fill="white" opacity="0.85"/>
        <rect x="176" y="61" width="16" height="7" rx="1" fill="white" opacity="0.6"/>
        <rect x="126" y="74" width="18" height="5" rx="1" fill="white" opacity="0.85"/>
        <!-- Sub-problem 3 (bottom row) -->
        <rect x="76" y="88" width="18" height="7" rx="1" fill="white" opacity="0.85"/>
        <rect x="100" y="88" width="14" height="7" rx="1" fill="white" opacity="0.6"/>
        <rect x="76" y="101" width="14" height="7" rx="1" fill="white" opacity="0.6"/>
        <rect x="100" y="101" width="18" height="7" rx="1" fill="white" opacity="0.85"/>
        <rect x="76" y="114" width="18" height="5" rx="1" fill="white" opacity="0.85"/>
        <!-- Zero blocks (lower-left and upper-right submatrices) - just faint outlines -->
        <rect x="76" y="8" width="116" height="30" rx="1" stroke="white" stroke-width="0.5" opacity="0.25"/>
        <rect x="8" y="48" width="56" height="106" rx="1" stroke="white" stroke-width="0.5" opacity="0.25"/>
        <!-- Labels -->
        <text x="35" y="170" font-size="9" fill="white" opacity="0.5" text-anchor="middle" font-family="monospace">master</text>
        <text x="134" y="170" font-size="9" fill="white" opacity="0.5" text-anchor="middle" font-family="monospace">sub-problems</text>
      </svg>
    </div>

    <div class="relative mx-auto max-w-3xl">
      <p class="text-xs font-mono uppercase tracking-widest text-sky-400 mb-3 opacity-80">
        Column Generation · Linear Programming · Decomposition
      </p>
      <h1
        class="text-5xl sm:text-7xl font-bold tracking-tight mb-6 leading-tight"
        style="font-family: 'Crimson Pro', 'STIX Two Math', ui-serif, Georgia, serif;"
      >
        Dantzig&#8209;Wolfe<br />
        <span class="text-sky-300">Decomposition</span>
      </h1>
      <p class="text-lg text-slate-300 leading-relaxed max-w-xl">
        Solve large-scale linear programmes with block-angular structure by decomposing them
        into a <strong class="text-white">master problem</strong> and independent
        <strong class="text-white">sub-problems</strong>, communicating through column generation.
      </p>
    </div>
  </section>

  <!-- Section cards -->
  <section class="py-12 px-4" aria-label="Site sections">
    <div class="mx-auto max-w-5xl">
      <h2 class="sr-only">Explore the site</h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-6" role="list">
        {
          sections.map(({ href, label, icon, teaser }) => (
            <li>
              <a
                href={href}
                class="block h-full rounded-lg border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-[var(--color-accent)] transition-all"
              >
                <p class="text-2xl mb-2" aria-hidden="true">
                  {icon}
                </p>
                <h3 class="text-lg font-semibold text-[var(--color-primary)] mb-1">{label}</h3>
                <p class="text-sm text-gray-600 leading-relaxed">{teaser}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <Footer slot="footer" />

  <!-- Glossary island — listens for open-glossary events site-wide -->
  <GlossaryPanel client:only="svelte" entries={glossaryData} />
</BaseLayout>
