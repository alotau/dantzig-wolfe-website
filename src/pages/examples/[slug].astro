---
import BaseLayout from '../../components/layout/BaseLayout.astro'
import NavBar from '../../components/layout/NavBar.astro'
import Footer from '../../components/layout/Footer.astro'
import GlossaryPanel from '../../components/layout/GlossaryPanel.svelte'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const entries = await getCollection('examples')
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content } = await entry.render()

const glossaryEntries = await getCollection('glossary')
const glossaryData = glossaryEntries.map((e) => ({
  term: e.data.term,
  shortDef: e.data.shortDef,
  relatedTerms: e.data.relatedTerms,
  slug: e.slug,
}))

const badgeLabels: Record<string, string> = {
  'network-flow': 'Network Flow',
  scheduling: 'Scheduling',
  'cutting-stock': 'Cutting Stock',
  other: 'Other',
}
---

<BaseLayout
  title={`${entry.data.title} — Worked Example`}
  description={entry.data.description ??
    `A worked example of Dantzig-Wolfe Decomposition: ${entry.data.title}`}
>
  <NavBar slot="nav" />
  <GlossaryPanel client:only="svelte" entries={glossaryData} />

  <div class="mx-auto max-w-3xl px-4 py-10">
    <nav class="mb-6 text-sm text-gray-500" aria-label="Breadcrumb">
      <a href="/examples" class="hover:underline text-[var(--color-accent)]">Examples</a>
      <span class="mx-2">›</span>
      <span class="text-gray-700">{entry.data.title}</span>
    </nav>

    <div class="flex items-center gap-3 mb-2">
      <h1 class="text-3xl font-bold text-[var(--color-primary)]">{entry.data.title}</h1>
      <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700">
        {badgeLabels[entry.data.problemClass] ?? entry.data.problemClass}
      </span>
    </div>

    {
      entry.data.description && (
        <p class="mb-8 text-lg text-gray-600 leading-relaxed">{entry.data.description}</p>
      )
    }

    <article class="prose prose-gray max-w-none">
      <Content />
    </article>
  </div>

  <Footer slot="footer" />
</BaseLayout>
