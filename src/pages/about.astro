---
import BaseLayout from '../components/layout/BaseLayout.astro'
import NavBar from '../components/layout/NavBar.astro'
import Footer from '../components/layout/Footer.astro'
import GlossaryPanel from '../components/layout/GlossaryPanel.svelte'
import { getCollection } from 'astro:content'

const glossaryEntries = await getCollection('glossary')
const glossaryData = glossaryEntries.map((e) => ({
  term: e.data.term,
  shortDef: e.data.shortDef,
  relatedTerms: e.data.relatedTerms,
  slug: e.slug,
}))
---

<BaseLayout
  title="About — Dantzig-Wolfe Decomposition"
  description="About the Dantzig-Wolfe Decomposition website — contact information, GitHub repositories, and the motivation behind the project."
>
  <NavBar slot="nav" />

  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold tracking-tight text-[var(--color-text-primary)] mb-10">About</h1>

    <!-- ------------------------------------------------------------------ -->
    <!-- Contact                                                              -->
    <!-- ------------------------------------------------------------------ -->
    <section class="mb-10" aria-labelledby="contact-heading">
      <h2
        id="contact-heading"
        class="text-xl font-semibold text-[var(--color-text-primary)] mb-3 border-b border-gray-200 pb-2"
      >
        Contact
      </h2>
      <p class="text-[var(--color-text-secondary)] leading-relaxed">
        Have a question, spotted an error, or want to contribute? Feel free to get in touch.
      </p>
      <p class="mt-3">
        <a
          href="mailto:contact@example.com"
          class="text-[var(--color-accent)] underline hover:opacity-80 transition-opacity"
        >
          {/* TODO: Replace with the author's actual email address */}
          contact@example.com
        </a>
      </p>
    </section>

    <!-- ------------------------------------------------------------------ -->
    <!-- Links / GitHub                                                       -->
    <!-- ------------------------------------------------------------------ -->
    <section class="mb-10" aria-labelledby="links-heading">
      <h2
        id="links-heading"
        class="text-xl font-semibold text-[var(--color-text-primary)] mb-3 border-b border-gray-200 pb-2"
      >
        GitHub
      </h2>
      <p class="text-[var(--color-text-secondary)] mb-4 leading-relaxed">
        Both this website and the underlying Python solver are open source.
      </p>
      <ul class="space-y-3 text-sm">
        <li>
          <a
            href="https://github.com/alotau/dantzig-wolfe-website"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-[var(--color-accent)] underline hover:opacity-80 transition-opacity"
          >
            <!-- GitHub icon (inline SVG) -->
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.04c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5 1 .11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.04.14 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.66 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12C24 5.37 18.63 0 12 0z"
              ></path>
            </svg>
            Website Source on GitHub
          </a>
          <span class="ml-1 text-[var(--color-text-muted)]"
            >— source code for this educational site</span
          >
        </li>
        <li>
          <a
            href="https://github.com/alotau/dantzig-wolfe-python"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-[var(--color-accent)] underline hover:opacity-80 transition-opacity"
          >
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.04c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5 1 .11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.04.14 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.66 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12C24 5.37 18.63 0 12 0z"
              ></path>
            </svg>
            Dantzig-Wolfe Python Solver on GitHub
          </a>
          <span class="ml-1 text-[var(--color-text-muted)]"
            >— the Python solver that powers the interactive solver on this site</span
          >
        </li>
      </ul>
    </section>

    <!-- ------------------------------------------------------------------ -->
    <!-- Motivation                                                           -->
    <!-- ------------------------------------------------------------------ -->
    <section class="mb-10" aria-labelledby="motivation-heading" data-section="motivation">
      <h2
        id="motivation-heading"
        class="text-xl font-semibold text-[var(--color-text-primary)] mb-3 border-b border-gray-200 pb-2"
      >
        Motivation
      </h2>
      {
        /*
        TODO: Replace the placeholder paragraph below with the author's own words explaining
        why this site was built. The text should describe the personal motivation behind the
        project, the intended audience, and what makes this resource different from existing
        literature on Dantzig-Wolfe Decomposition.
      */
      }
      <p class="text-[var(--color-text-secondary)] leading-relaxed">
        This site was built to make Dantzig-Wolfe Decomposition more accessible to students and
        practitioners who want a structured, interactive introduction to the algorithm. Existing
        resources tend to be either too terse (a few paragraphs in a textbook) or too dense (full
        research papers). The goal here is a middle ground: rigorous enough to be useful,
        interactive enough to build intuition.
      </p>
    </section>
  </div>

  <GlossaryPanel client:only="svelte" terms={glossaryData} slot="default" />

  <Footer slot="footer" />
</BaseLayout>
