---
import '../../styles/global.css'

interface Props {
  title: string
  description?: string
  ogImage?: string
}

const {
  title,
  description = 'An interactive educational site exploring Dantzig-Wolfe Decomposition — history, lesson, worked examples, and an in-browser solver.',
  ogImage = '/og-default.png',
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://alotau.github.io')
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>

    <!-- Google Fonts: Crimson Pro (display serif for hero titles) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Page-specific head content (meta, preloads, etc.) -->
    <slot name="head" />
  </head>
  <body>
    <!-- Skip to main for keyboard / screen reader navigation (WCAG 2.4.1) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded focus:bg-[var(--color-accent)] focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to main content
    </a>

    <!-- NavBar island slot — filled by each page -->
    <slot name="nav" />

    <main id="main-content">
      <slot />
    </main>

    <!-- Footer slot — filled by each page or defaults below -->
    <slot name="footer" />
  </body>
</html>
