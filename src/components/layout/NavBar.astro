---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/history', label: 'History' },
  { href: '/lesson', label: 'Lesson' },
  { href: '/examples', label: 'Examples' },
  { href: '/about', label: 'About' },
  { href: '/solver', label: 'Solver' },
]

const pathname = Astro.url.pathname

function isActive(href: string) {
  if (href === '/') return pathname === '/'
  return pathname.startsWith(href)
}
---

<header
  class="sticky top-0 z-40 bg-[var(--color-primary)] text-[var(--color-text-inverse)] shadow-md"
>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <nav aria-label="Primary navigation" class="flex items-center justify-between h-14">
      <!-- Skip-to-main handled in BaseLayout; site name shortcut -->
      <a
        href="/"
        class="font-semibold text-sm tracking-wide hover:text-[var(--color-accent)] transition-colors"
      >
        DW Decomposition
      </a>

      <!-- Desktop links -->
      <ul class="hidden sm:flex items-center gap-1 text-sm" role="list">
        {
          navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                aria-current={isActive(href) ? 'page' : undefined}
                data-active={isActive(href) ? 'true' : undefined}
                class:list={[
                  'px-3 py-1 rounded transition-colors',
                  isActive(href) ? 'bg-white/20 font-semibold' : 'hover:bg-white/10',
                ]}
              >
                {label}
              </a>
            </li>
          ))
        }
        <li>
          <button
            type="button"
            aria-label="Open Glossary panel"
            onclick="window.dispatchEvent(new CustomEvent('open-glossary', { detail: {} }))"
            class="px-3 py-1 rounded border border-white/30 hover:bg-white/10 transition-colors text-sm cursor-pointer"
          >
            Glossary
          </button>
        </li>
      </ul>

      <!-- Mobile hamburger (controlled by <details>) -->
      <details class="sm:hidden relative" id="nav-mobile">
        <summary
          class="list-none cursor-pointer p-2 rounded hover:bg-white/10 transition-colors"
          aria-label="Toggle navigation menu"
        >
          <!-- Hamburger icon -->
          <svg aria-hidden="true" width="22" height="22" viewBox="0 0 22 22" fill="currentColor">
            <rect y="4" width="22" height="2" rx="1"></rect>
            <rect y="10" width="22" height="2" rx="1"></rect>
            <rect y="16" width="22" height="2" rx="1"></rect>
          </svg>
        </summary>
        <ul
          class="absolute right-0 top-full mt-1 w-48 rounded-md bg-[var(--color-primary)] shadow-lg py-1 text-sm"
          role="list"
        >
          {
            navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  aria-current={isActive(href) ? 'page' : undefined}
                  data-active={isActive(href) ? 'true' : undefined}
                  class:list={[
                    'block px-4 py-2 hover:bg-white/10 transition-colors',
                    isActive(href) ? 'font-semibold bg-white/15' : '',
                  ]}
                  onclick="document.getElementById('nav-mobile').removeAttribute('open')"
                >
                  {label}
                </a>
              </li>
            ))
          }
          <li>
            <button
              type="button"
              aria-label="Open Glossary panel"
              onclick="window.dispatchEvent(new CustomEvent('open-glossary', { detail: {} })); document.getElementById('nav-mobile').removeAttribute('open')"
              class="block w-full text-left px-4 py-2 hover:bg-white/10 transition-colors cursor-pointer"
            >
              Glossary
            </button>
          </li>
        </ul>
      </details>
    </nav>
  </div>
</header>
