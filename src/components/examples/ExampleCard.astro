---
interface Props {
  title: string
  problemClass: 'network-flow' | 'scheduling' | 'cutting-stock' | 'other'
  description?: string
  source: string
  slug: string
}

const { title, problemClass, description, source, slug } = Astro.props

const badgeLabels: Record<string, string> = {
  'network-flow': 'Network Flow',
  scheduling: 'Scheduling',
  'cutting-stock': 'Cutting Stock',
  other: 'Other',
}

const badgeColors: Record<string, string> = {
  'network-flow': 'bg-blue-100 text-blue-800',
  scheduling: 'bg-green-100 text-green-800',
  'cutting-stock': 'bg-orange-100 text-orange-800',
  other: 'bg-gray-100 text-gray-700',
}
---

<article
  data-example-card
  data-problem-class={problemClass}
  class="rounded-lg border border-gray-200 p-6 hover:shadow-md transition-shadow"
>
  <div class="flex items-start justify-between gap-4 mb-3">
    <h2 class="text-xl font-semibold text-[var(--color-primary)]">
      <a href={`/examples/${slug}`} class="hover:underline">{title}</a>
    </h2>
    <span
      class={`shrink-0 rounded-full px-2 py-0.5 text-xs font-medium ${badgeColors[problemClass]}`}
    >
      {badgeLabels[problemClass]}
    </span>
  </div>

  {description && <p class="mb-3 text-gray-600 text-sm leading-relaxed">{description}</p>}

  <cite class="block text-xs text-gray-500 not-italic border-l-2 border-gray-200 pl-2">
    {source}
  </cite>
</article>
