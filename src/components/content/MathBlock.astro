---
import katex from 'katex'

interface Props {
  formula: string
  /** Optional accessible label for screen readers */
  label?: string
}

const { formula, label } = Astro.props

let rendered = ''
let renderError = ''

try {
  rendered = katex.renderToString(formula, {
    displayMode: true,
    throwOnError: false,
    trust: false,
  })
} catch (err) {
  renderError = err instanceof Error ? err.message : String(err)
}
---

<div class="katex-display-wrapper my-4" role="math" aria-label={label ?? formula}>
  {
    renderError ? (
      <pre class="text-red-600 text-sm">[KaTeX error: {renderError}]</pre>
    ) : (
      <Fragment set:html={rendered} />
    )
  }
</div>
