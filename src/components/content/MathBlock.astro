---
import katex from 'katex'

interface Props {
  formula: string
  /** Optional accessible label for screen readers */
  label?: string
}

const { formula, label } = Astro.props

// If the formula contains bare & (alignment tabs) not already inside a \begin{}
// environment, wrap it in \begin{aligned}...\end{aligned} so KaTeX can parse it.
function prepareFormula(f: string): string {
  if (!f) return f
  const hasAlignment = /(?<!\\begin\{[^}]*\})&/.test(f) || (f.includes('&') && !/\\begin\{/.test(f))
  if (hasAlignment && !/\\begin\{/.test(f)) {
    return `\\begin{aligned}${f}\\end{aligned}`
  }
  return f
}

let rendered = ''
let renderError = ''

try {
  rendered = katex.renderToString(prepareFormula(formula), {
    displayMode: true,
    throwOnError: false,
    trust: false,
  })
} catch (err) {
  renderError = err instanceof Error ? err.message : String(err)
}
---

<div class="katex-display-wrapper my-4" role="math" aria-label={label ?? formula}>
  {
    renderError ? (
      <pre class="text-red-600 text-sm">[KaTeX error: {renderError}]</pre>
    ) : (
      <Fragment set:html={rendered} />
    )
  }
</div>
